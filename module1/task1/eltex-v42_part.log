touch "$USER"_part.log
1) screen -S `whoami`_part2
2) ls           lsb_release  lsinitramfs  lslocks      lsmod        lspci
lsattr       lscpu        lsipc        lslogins     lsns         lsusb
lsblk        lsfd         lsirq        lsmem        lsof
3) $HISTCMD       $HISTCONTROL   $HISTFILE      $HISTFILESIZE  $HISTSIZE
4) echo $HISTFILESIZE # 2000
5) ls -d ~/.*
6) export HISTTIMEFORMAT="%d.%m.%Y %H:%M:%S "
7)
- date
- history # Есть команда date;
  tail -10 ~/.bash_history  # Нет команды date.
- export PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"
- date
  history # Есть команда date;
  tail -10 ~/.bash_history # Тоже есть команда date
10) DATE=`date +%Y-%m-%d`
    echo $DATE # 2026.07.08
11) TIME=`date +%H:%M:%S`
    echo $TIME # 00.40.40
12) DATE_TIME="$DATE $TIME"
    echo $DATE_TIME # 2026-07-08 00:40:40
13) ls /bin /sbin | grep '[0-9]'
14) export PS1="\u@\h-$(date +%H:%M)> "
15) bash # Приглашение стандартное
    echo 'export PS1="\u@\h-$(date +%H:%M)> "' >> ~/.bashrc
    bash # Приглашение такое же, как и в родительском интерпретаторе
16) for month in {01..12}; do mkdir -p ~/$(date +%Y)-$month; done
